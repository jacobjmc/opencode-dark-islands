    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxString": {
      "dark": "greenStr",
      "light": "greenStr"
    },
    "syntaxNumber": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxType": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxOperator": {
      "dark": "fgMuted",
      "light": "fgMuted"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    }
