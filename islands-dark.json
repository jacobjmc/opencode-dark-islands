{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#141821",
    "bgDeep": "#0d1117",
    "bgPanel": "#12161c",
    "bgElem": "#171a1e",
    "bgSel": "#262b34",
    "fg": "#c4cad3",
    "fgMuted": "#7e8793",
    "blue": "#52A0E9",
    "blueBr": "#78B9F2",
    "orange": "#d7a77a",
    "green": "#91d49c",
    "greenStr": "#9ddda6",
    "purple": "#c7aae7",
    "cyan": "#72BCD7",
    "red": "#c26b74",
    "yellow": "#e1ca84",
    "border": "#252a33",
    "borderMid": "#343a45"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "green",
      "light": "green"
    },
    "accent": {
      "dark": "blue",
      "light": "blue"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
